# ===========================================
# Resume RAG Chatbot - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---------- REQUIRED ----------

# Your Gemini API key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ---------- OPTIONAL ----------

# Gemini model for chat generation (default: gemini-2.5-flash)
GEMINI_CHAT_MODEL=gemini-2.5-flash

# Gemini model for embeddings (default: text-embedding-004)
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# CORS allowed origins (comma-separated, default: *)
CORS_ORIGINS=*

# Rate limit: requests per minute per IP (default: 10)
RATE_LIMIT=10/minute

# Retrieval settings
TOP_K=5
SIMILARITY_THRESHOLD=0.3

# Server port (default: 8000)
PORT=8000
